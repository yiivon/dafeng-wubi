# Normalize line endings — text files use LF, binaries are untouched.
* text=auto eol=lf

*.png binary
*.jpg binary
*.ico binary
*.icns binary
*.pdf binary
*.mlx binary
*.bin binary
*.db binary

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.sln text eol=crlf
